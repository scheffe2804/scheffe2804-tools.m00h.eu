# Matomo-Tracking für Landing Page
# Matomo-Site für tools.m00h.eu unter https://stats.sauerlandaktuell.de anlegen,
# dann SITE_ID hier eintragen und in landing/index.html ersetzen.
MATOMO_URL=https://stats.sauerlandaktuell.de
MATOMO_SITE_ID=

# Shlink – API-Key wird beim ersten Start automatisch generiert,
# danach in /srv/tools-m00h-eu/secrets/shlink.env hinterlegen:
# INITIAL_API_KEY=<generierter-key>
